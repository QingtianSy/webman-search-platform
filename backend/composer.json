{
  "name": "qingtiansy/webman-search-platform-backend",
  "type": "project",
  "description": "Production-grade search platform backend based on Webman architecture",
  "require": {
    "php": ">=8.2",
    "webman/framework": "^2.1",
    "workerman/workerman": "^5.1",
    "vlucas/phpdotenv": "^5.6",
    "monolog/monolog": "^3.7",
    "guzzlehttp/guzzle": "^7.9",
    "mongodb/mongodb": "^1.19",
    "elasticsearch/elasticsearch": "^8.15"
  },
  "autoload": {
    "psr-4": {
      "app\\": "app/",
      "support\\": "support/"
    },
    "files": [
      "support/helpers.php"
    ]
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
