{
  "name": "qingtiansy/webman-search-platform-backend",
  "type": "project",
  "description": "Production-grade search platform backend based on Webman architecture",
  "require": {
    "php": ">=8.2",
    "workerman/webman-framework": "^1.6",
    "workerman/workerman": "^5.1",
    "vlucas/phpdotenv": "^5.6",
    "monolog/monolog": "^3.7",
    "guzzlehttp/guzzle": "^7.9",
    "mongodb/mongodb": "^1.19",
    "elasticsearch/elasticsearch": "^8.15"
  },
  "suggest": {
    "ext-swoole": "用于高性能运行时支持",
    "ext-redis": "用于 Redis 扩展支持",
    "ext-mongodb": "用于 MongoDB 扩展支持"
  },
  "autoload": {
    "psr-4": {
      "app\\": "app/",
      "support\\": "support/"
    },
    "files": [
      "support/helpers.php"
    ]
  },
  "scripts": {
    "smoke": [
      "php tests/auth_mock_smoke.php",
      "php tests/search_mock_smoke.php",
      "php tests/dashboard_mock_smoke.php"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
