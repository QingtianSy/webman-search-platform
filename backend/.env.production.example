# 生产环境变量示例

APP_NAME=webman-search-platform
APP_ENV=prod
APP_DEBUG=false
APP_URL=https://your-domain.com

AUTH_RBAC_SOURCE=real
QUESTION_SOURCE=real
LOG_SOURCE=real

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=search_platform
MYSQL_USERNAME=search_user
MYSQL_PASSWORD=please_change_me

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DATABASE=search_platform

ES_HOST=http://127.0.0.1:9200
ES_USERNAME=
ES_PASSWORD=

JWT_SECRET=please_change_me_to_long_random_string
JWT_EXPIRE=604800
