VITE_BASE=/

# 接口地址（Nginx 反代 /api/ → Webman :8787，前端发 /api/v1/** 即可）
VITE_GLOB_API_URL=/api/v1

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=none

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式：history → URL 干净（/auth/register 而非 /#/auth/register）
# 注意：nginx 必须配 try_files $uri $uri/ /index.html; 否则刷新非根路径会 404
VITE_ROUTER_HISTORY=history

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 打包后是否生成dist.zip
VITE_ARCHIVER=true
